# ─── DCS Ops Center — Production Environment ─────────────────────────────────
# Copy this file to .env.prod and fill in all CHANGE_ME values.
# Keep .env.prod out of version control (it's in .gitignore).

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=dcs_ops
POSTGRES_USER=postgres
# Use a strong random password, e.g.: openssl rand -base64 24
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# ─── Better Auth ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=CHANGE_ME_run_openssl_rand_base64_32

# Set to the public URL of the server (used for auth callbacks)
# If behind a reverse proxy (nginx/caddy) with HTTPS, use https://
BETTER_AUTH_URL=http://10.6.104.13:3000

# ─── CORS ────────────────────────────────────────────────────────────────────
# Must match the exact origin the browser uses to load the app.
# Same as BETTER_AUTH_URL unless running a separate front-end.
CORS_ORIGIN=http://10.6.104.13:3000

# ─── Ports ────────────────────────────────────────────────────────────────────
# Port the app container binds on the host
APP_PORT=3000
# Port the docs container binds on the host
DOCS_PORT=4000

# ─── GitHub Container Registry ────────────────────────────────────────────────
# A GitHub Personal Access Token with `read:packages` scope.
# Create at: https://github.com/settings/tokens/new?scopes=read:packages
# Used by the deploy script to pull images from ghcr.io/kareemschultz/
GHCR_TOKEN=CHANGE_ME_github_pat_with_read_packages_scope
